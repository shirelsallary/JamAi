# Database
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname

# JWT
SECRET_KEY=change-this-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# Spotify OAuth
SPOTIFY_CLIENT_ID=your-spotify-client-id
SPOTIFY_CLIENT_SECRET=your-spotify-client-secret
# Must be the app's deep link, NOT a backend URL — an external browser can't
# reach a backend endpoint with the user's JWT. Register this exact value in
# the Spotify Developer Dashboard for your app, and it must match what the
# Android app declares as its intent-filter (see AndroidManifest.xml).
SPOTIFY_REDIRECT_URI=jamai://spotify-callback

# YouTube OAuth
YOUTUBE_CLIENT_ID=your-youtube-client-id
YOUTUBE_CLIENT_SECRET=your-youtube-client-secret

# Token encryption
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=generate-with-fernet
