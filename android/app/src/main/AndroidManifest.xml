<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Required for mobile_scanner's in-app QR camera (JoinSessionScreen).
         mobile_scanner's own plugin manifest already declares this, which
         Android's manifest merger would pull in automatically — declared
         explicitly here too so the app's own manifest documents its real
         permission surface rather than relying on an implicit merge from a
         dependency. android:required="false" on the feature declaration
         matches mobile_scanner's own (camera is optional: manual code entry
         on JoinSessionScreen always works without it). -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <application
        android:label="JAM AI"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
            <!-- Bug 2 fix: jamai:// deep links — used for the Spotify OAuth
                 callback (jamai://spotify-callback?code=...&state=...) so the
                 app can intercept Spotify's redirect instead of it going
                 nowhere. Also covers the pre-existing jamai://join/{code} QR
                 payload (app/services/session_service.py), which — separately
                 from this fix, noted but not touched — had no matching
                 intent-filter either, so QR-code joining doesn't deep-link
                 into the app today. -->
            <intent-filter android:autoVerify="false">
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="jamai"/>
            </intent-filter>
        </activity>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

        <!-- App-to-App Spotify auth: com.spotify.android:auth brings in its own
             RedirectUriReceiverActivity, exported with an intent-filter for
             ${redirectSchemeName}/${redirectHostName} (set to jamai/spotify-callback
             below to satisfy the library's manifest placeholders) — the exact same
             scheme+host MainActivity's own jamai:// intent-filter above already
             claims for the existing, working browser-flow deep link. We only use
             this library for App-to-App SSO (AuthorizationClient, launched only
             after confirming the Spotify app is installed) and deliberately never
             use its Custom-Tabs browser-fallback path, so this activity is removed
             from the merged manifest to avoid two components racing to handle the
             same jamai://spotify-callback redirect and breaking the existing
             browser flow's deep-link delivery. -->
        <activity
            android:name="com.spotify.sdk.android.auth.browser.RedirectUriReceiverActivity"
            tools:node="remove" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin.

         Also declares com.spotify.music explicitly for App-to-App Spotify auth
         install detection — com.spotify.android:auth's own bundled manifest
         already declares this (plus its debug/canary/partners variants) via its
         com.spotify.sso.action.START_AUTH_FLOW intent query, so this entry is
         belt-and-suspenders, not strictly required by the merged manifest. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <package android:name="com.spotify.music"/>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="https" />
        </intent>
        <intent>
            <action android:name="android.intent.action.VIEW" />
            <category android:name="android.intent.category.BROWSABLE" />
            <data android:scheme="http" />
        </intent>
    </queries>
</manifest>
